<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialogo"
    android:padding="24dp">

    <TextView
        android:id="@+id/txtTituloEditar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Editar reto"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="18sp"
        app:layout_constraintTop_toTopOf="parent"/>

    <EditText
        android:id="@+id/etRetoEditar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:backgroundTint="#FF6800"
        app:layout_constraintTop_toBottomOf="@id/txtTituloEditar"/>

    <Button
        android:id="@+id/btnCancelarEditar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Cancelar"
        android:textAllCaps="false"
        android:backgroundTint="#FF6800"
        android:textColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/etRetoEditar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnGuardarEditar"/>

    <Button
        android:id="@+id/btnGuardarEditar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Guardar"
        android:textAllCaps="false"
        android:backgroundTint="#FF6800"
        android:textColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/etRetoEditar"
        app:layout_constraintStart_toEndOf="@id/btnCancelarEditar"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>