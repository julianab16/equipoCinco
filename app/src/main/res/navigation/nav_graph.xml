<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/configuracionesFragment"
        android:name="com.desarrollodpmoviles.picobotelladapdm.ui.configuraciones.ConfiguracionesFragment"
        android:label="fragment_configuraciones"
        tools:layout="@layout/fragment_configuraciones" />

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.desarrollodpmoviles.picobotelladapdm.ui.home.HomeFragment"
        android:label="fragment_home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_homeFragment_to_instruccionesFragment"
            app:destination="@id/instruccionesFragment"/>

    </fragment>

    <fragment
        android:id="@+id/instruccionesFragment"
        android:name="com.desarrollodpmoviles.picobotelladapdm.ui.instrucciones.InstruccionesFragment"
        android:label="fragment_instrucciones"
        tools:layout="@layout/fragment_instrucciones" />
    <fragment
        android:id="@+id/juegoFragment"
        android:name="com.desarrollodpmoviles.picobotelladapdm.ui.juego.JuegoFragment"
        android:label="fragment_juego"
        tools:layout="@layout/fragment_juego" />
    <fragment
        android:id="@+id/splashFragment"
        android:name="com.desarrollodpmoviles.picobotelladapdm.ui.splash.SplashFragment"
        android:label="fragment_splash"
        tools:layout="@layout/fragment_splash">

        <action
            android:id="@+id/action_splashFragment_to_homeFragment"
            app:destination="@id/homeFragment"/>

    </fragment>
</navigation>